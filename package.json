{
  "name": "timeline",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev -w @timeline/api\" \"npm run dev -w @timeline/web\"",
    "build": "npm run build -w @timeline/shared && npm run build -w @timeline/api && npm run build -w @timeline/web",
    "db:generate": "npm run db:generate -w @timeline/api",
    "db:migrate": "npm run db:migrate -w @timeline/api",
    "db:seed": "npm run db:seed -w @timeline/api"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/turndown": "^5.0.6",
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@tiptap/extension-placeholder": "^3.25.0",
    "@tiptap/react": "^3.25.0",
    "@tiptap/starter-kit": "^3.25.0",
    "marked": "^18.0.5",
    "turndown": "^7.2.4"
  }
}
