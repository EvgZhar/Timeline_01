DATABASE_URL=postgresql://timeline:password@localhost:5432/timeline
PORT=3001
# 32-byte key as 64 hex characters (generate: openssl rand -hex 32)
SETTINGS_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# JWT — 64-byte key as 128 hex characters (generate: openssl rand -hex 64)
JWT_SECRET=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# SMTP (Яндекс.Почта)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your-email@yandex.ru
SMTP_PASS=your-app-password

# OAuth — Яндекс
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# OAuth — VK
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# URLs
AUTH_CALLBACK_URL=http://localhost:3001
FRONTEND_URL=http://localhost:5173
