{
  "name": "@timeline/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "DATABASE_URL=../../data/timeline.db tsx src/db/migrate.ts",
    "db:seed": "DATABASE_URL=../../data/timeline.db tsx src/db/seed.ts",
    "dev": "DATABASE_URL=../../data/timeline.db tsx watch src/index.ts"
  },
  "dependencies": {
    "@timeline/shared": "*",
    "better-sqlite3": "^11.9.1",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.41.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "multer": "^1.4.5-lts.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.1",
    "drizzle-kit": "^0.30.6",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
