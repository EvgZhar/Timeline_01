{
  "name": "@timeline/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node --env-file=../../.env ../../node_modules/.bin/tsx src/db/migrate.ts",
    "db:seed": "node --env-file=../../.env ../../node_modules/.bin/tsx src/db/seed.ts",
    "db:cleanup-tokens": "node --env-file=../../.env ../../node_modules/.bin/tsx src/db/cleanup-tokens.ts",
    "rate-limit:reset": "kill -9 $(lsof -ti :3001) 2>/dev/null; echo 'Готово — лимиты сброшены, API перезапускается'",
    "dev": "node --env-file=../../.env ../../node_modules/.bin/tsx watch src/index.ts"
  },
  "dependencies": {
    "@timeline/shared": "*",
    "better-sqlite3": "^11.9.1",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.2",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "multer": "^1.4.5-lts.2",
    "nodemailer": "^8.0.9",
    "pg": "^8.21.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.1",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
